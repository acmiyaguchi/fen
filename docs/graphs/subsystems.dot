  "cli" -> "core.llm";
  "cli" -> "extension.tui";
  "cli" -> "other";
  "cli" -> "util";
  "core" -> "core.extensions";
  "core" -> "core.llm";
  "core" -> "util";
  "core.extensions" -> "core";
  "core.extensions" -> "core.llm";
  "core.extensions" -> "util";
