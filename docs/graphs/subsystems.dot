  "extension.skills" [fillcolor="lightyellow", label="extension: skills\n5 modules", style="filled"];
  "extension.status" [fillcolor="lightyellow", label="extension: status\n4 modules", style="filled"];
  "extension.stdio" [fillcolor="lightyellow", label="extension: stdio\n1 modules", style="filled"];
  "extension.todo" [fillcolor="lightyellow", label="extension: todo\n2 modules", style="filled"];
  "extension.tui" [fillcolor="lightyellow", label="extension: tui\n13 modules", style="filled"];
  "extension.web" [fillcolor="lightyellow", label="extension: web\n6 modules", style="filled"];
