digraph fen_essentials {
  graph [rankdir=LR];
  node [shape=box, fontname="monospace"];
  edge [fontname="monospace"];
  "fen.extensions.essentials" [fillcolor="lightyellow", label="fen.extensions.essentials", style="filled", tooltip="extensions/behaviors/kernel/essentials/init.fnl persistent"];
  "fen.extensions.essentials.commands.help" [fillcolor="lightyellow", label="fen.extensions.essentials.commands.help", style="filled", tooltip="extensions/behaviors/kernel/essentials/commands/help.fnl persistent"];
  "fen.extensions.essentials.commands.model" [fillcolor="lightyellow", label="fen.extensions.essentials.commands.model", style="filled", tooltip="extensions/behaviors/kernel/essentials/commands/model.fnl persistent"];
  "fen.extensions.essentials" -> "fen.extensions.essentials.commands.help" [label="require"];
  "fen.extensions.essentials" -> "fen.extensions.essentials.commands.model" [label="require"];
}
