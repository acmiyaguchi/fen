digraph fen_prompt {
  graph [rankdir=LR];
  node [shape=box, fontname="monospace"];
  edge [fontname="monospace"];
  "fen.extensions.prompt" [fillcolor="lightyellow", label="fen.extensions.prompt", style="filled", tooltip="extensions/behaviors/inspectors/prompt/init.fnl persistent"];
  "fen.extensions.prompt.commands.prompt" [fillcolor="lightyellow", label="fen.extensions.prompt.commands.prompt", style="filled", tooltip="extensions/behaviors/inspectors/prompt/commands/prompt.fnl persistent"];
  "fen.extensions.prompt.state.prompt" [fillcolor="lightyellow", label="fen.extensions.prompt.state.prompt", style="filled", tooltip="extensions/behaviors/inspectors/prompt/state/prompt.fnl persistent"];
  "fen.extensions.prompt" -> "fen.extensions.prompt.commands.prompt" [label="require"];
  "fen.extensions.prompt.commands.prompt" -> "fen.extensions.prompt.state.prompt" [label="require"];
}
