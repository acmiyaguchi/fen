digraph fen_subsystems {
  graph [rankdir=LR];
  node [shape=box, fontname="monospace"];
  edge [fontname="monospace"];
  "cli" [fillcolor="lightblue", label="CLI\n2 modules", style="filled"];
  "core" [fillcolor="palegreen", label="core\n6 modules", style="filled"];
  "core.extensions" [fillcolor="palegreen", label="core.extensions\n22 modules", style="filled"];
  "core.llm" [fillcolor="palegreen", label="core.llm\n4 modules", style="filled"];
  "extension.agent_state" [fillcolor="lightyellow", label="extension: agent_state\n2 modules", style="filled"];
  "extension.builtin_commands" [fillcolor="lightyellow", label="extension: builtin_commands\n13 modules", style="filled"];
  "extension.builtin_tools" [fillcolor="lightyellow", label="extension: builtin_tools\n11 modules", style="filled"];
  "extension.default_prompt" [fillcolor="lightyellow", label="extension: default_prompt\n2 modules", style="filled"];
  "extension.docs" [fillcolor="lightyellow", label="extension: docs\n2 modules", style="filled"];
  "extension.handoff" [fillcolor="lightyellow", label="extension: handoff\n1 modules", style="filled"];
  "extension.mem" [fillcolor="lightyellow", label="extension: mem\n2 modules", style="filled"];
  "extension.print" [fillcolor="lightyellow", label="extension: print\n1 modules", style="filled"];
  "extension.provider_anthropic" [fillcolor="lightyellow", label="extension: provider_anthropic\n2 modules", style="filled"];
  "extension.provider_openai" [fillcolor="lightyellow", label="extension: provider_openai\n8 modules", style="filled"];
  "extension.session_jsonl" [fillcolor="lightyellow", label="extension: session_jsonl\n2 modules", style="filled"];
  "extension.skills" [fillcolor="lightyellow", label="extension: skills\n2 modules", style="filled"];
  "extension.stdio" [fillcolor="lightyellow", label="extension: stdio\n1 modules", style="filled"];
  "extension.tui" [fillcolor="lightyellow", label="extension: tui\n13 modules", style="filled"];
  "extension.web" [fillcolor="lightyellow", label="extension: web\n6 modules", style="filled"];
  "other" [fillcolor="white", label="other\n11 modules", style="filled"];
  "testing" [fillcolor="white", label="testing\n3 modules", style="filled"];
  "util" [fillcolor="white", label="util\n10 modules", style="filled"];
  "util.http" [fillcolor="white", label="util.http\n3 modules", style="filled"];
  "cli" -> "core";
  "cli" -> "core.extensions";
  "cli" -> "core.llm";
  "cli" -> "extension.tui";
  "cli" -> "util";
  "core" -> "core.extensions";
  "core" -> "core.llm";
  "core" -> "util";
  "core.extensions" -> "core";
  "core.extensions" -> "core.llm";
  "core.extensions" -> "util";
  "core.llm" -> "core.extensions";
  "core.llm" -> "util";
  "extension.agent_state" -> "core";
  "extension.agent_state" -> "util";
  "extension.builtin_commands" -> "cli";
  "extension.builtin_commands" -> "util";
  "extension.builtin_tools" -> "core";
  "extension.builtin_tools" -> "util";
  "extension.default_prompt" -> "util";
  "extension.docs" -> "core";
  "extension.docs" -> "util";
  "extension.handoff" -> "core";
  "extension.print" -> "core";
  "extension.provider_anthropic" -> "core";
  "extension.provider_anthropic" -> "core.llm";
  "extension.provider_anthropic" -> "util";
  "extension.provider_anthropic" -> "util.http";
  "extension.provider_openai" -> "core";
  "extension.provider_openai" -> "core.llm";
  "extension.provider_openai" -> "util";
  "extension.provider_openai" -> "util.http";
  "extension.session_jsonl" -> "util";
  "extension.skills" -> "util";
  "extension.stdio" -> "util";
  "extension.tui" -> "util";
  "extension.web" -> "util";
  "other" -> "cli";
  "other" -> "core";
  "other" -> "extension.tui";
  "other" -> "util";
  "testing" -> "core";
  "testing" -> "core.extensions";
  "testing" -> "extension.builtin_tools";
  "testing" -> "util";
}
