#!/bin/sh
# Drives the whole fen checkout from a single-file `fen` binary: every
# package's src/ tree becomes a Lua-module overlay, and the in-tree
# extensions root replaces a `make build` in the dev loop. Edit any
# .fnl, run `/reload`, see the change without rebuilding the binary.
#
# Override the launcher with FEN_BIN=/path/to/fen if `fen` isn't on
# PATH (e.g. point at result/bin/fen from a `nix build .#fenSingle`).
set -eu
SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
ROOT=$(dirname "$SCRIPT_DIR")
exec "${FEN_BIN:-fen}" \
  --dev-path "$ROOT/packages/core/src" \
  --dev-path "$ROOT/packages/util/src" \
  --dev-path "$ROOT/packages/fen/src" \
  --dev-path "$ROOT/packages/providers/openai/src" \
  --dev-path "$ROOT/packages/providers/openai-codex/src" \
  --dev-path "$ROOT/packages/providers/anthropic/src" \
  --extension-root "$ROOT/packages/extensions" \
  "$@"
