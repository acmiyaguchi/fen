#!/bin/sh
# Drives the whole fen checkout from a single-file `fen` binary: every
# package's src/ tree becomes a Lua-module overlay, and the in-tree
# extensions root replaces rebuilding in the dev loop. Edit any
# .fnl, run `/reload`, see the change without rebuilding the binary.
#
# Override the launcher with FEN_BIN=/path/to/fen if `fen` isn't on
# PATH (e.g. point at result/bin/fen from a `nix build .#fen`).
set -eu
SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
ROOT=$(dirname "$(dirname "$SCRIPT_DIR")")
default_dev_path="$ROOT/packages/core/src:$ROOT/packages/util/src:$ROOT/packages/fen/src"
default_extension_root="$ROOT/extensions"

export FEN_DEV_PATH="$default_dev_path${FEN_DEV_PATH:+:$FEN_DEV_PATH}"
export FEN_EXTENSION_ROOT="$default_extension_root${FEN_EXTENSION_ROOT:+:$FEN_EXTENSION_ROOT}"

exec "${FEN_BIN:-fen}" "$@"
